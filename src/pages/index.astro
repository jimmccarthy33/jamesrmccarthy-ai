---
import BaseLayout from '../layouts/BaseLayout.astro';
import TrackRecordList from '../components/TrackRecordList.astro';
import { getEntry } from 'astro:content';
import { site } from '../data/site';
import { trackRecord } from '../data/resume';

const manifesto = await getEntry('writing', site.manifestoSlug);
---

<BaseLayout description={site.description} path="/">
  <section class="hero">
    <div class="container">
      <div class="home-block hero__stack">
        <h1 class="hero__name">
          <span class="hero__name-line">James R.</span>
          <span class="hero__name-line">McCarthy</span>
        </h1>
        <p class="hero__goes-by">I go by Jim.</p>
        <p class="hero__thesis">{site.thesis}</p>
        <p class="hero__credential">{site.credential}</p>
      </div>
    </div>
  </section>

  {
    manifesto && !manifesto.data.draft && (
      <section class="home-section">
        <div class="container">
          <div class="home-block">
          <p class="section-kicker">Writing</p>
          <article class="editorial-row manifesto-row">
            <p class="editorial-row__meta">
              {manifesto.data.pubDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </p>
            <h2 class="editorial-row__title">
              <a href={`/writing/${manifesto.id}`}>{manifesto.data.title}</a>
            </h2>
            {manifesto.data.subtitle && (
              <p class="editorial-row__summary">{manifesto.data.subtitle}</p>
            )}
            <p class="editorial-row__summary">{manifesto.data.description}</p>
          </article>
          <a class="text-link" href={`/writing/${manifesto.id}`}>Read Everyone Builds →</a>
          <a class="text-link text-link--secondary" href="/writing">All writing →</a>
          </div>
        </div>
      </section>
    )
  }

  <section class="home-section">
    <div class="container">
      <div class="home-block">
        <p class="section-kicker">Track record</p>
        <TrackRecordList items={trackRecord} />
      </div>
    </div>
  </section>

  <section class="home-section">
    <div class="container">
      <div class="home-block">
        <p class="section-kicker">About</p>
        <p>
          I am an operator with a technology background. I moved from building software to running
          operations at scale, and I think in systems, cadence, margin integrity, and closed loops.
        </p>
        <p>
          I believe AI-native operating models let more people build at startup speed inside incumbent
          organizations. Not less process. More process, running faster, with human judgment on the
          decisions that matter.
        </p>
        <a class="text-link" href="/about">Full bio →</a>
      </div>
    </div>
  </section>

  <section class="home-section">
    <div class="container">
      <div class="home-block">
        <p class="section-kicker">Contact</p>
        <p>{site.contactTeaser}</p>
        <p>
          <a href={`mailto:${site.email}`}>{site.email}</a>
        </p>
        <a class="text-link" href="/contact">Contact →</a>
      </div>
    </div>
  </section>
</BaseLayout>
