---
import BaseLayout from '../layouts/BaseLayout.astro';
import { aboutVentures } from '../data/about';
import { site } from '../data/site';
import { resume } from '../data/resume';
---

<BaseLayout
  title="About"
  description={`About ${site.legalName} (${site.name}), C-suite operator with a technology and enterprise operations background.`}
  path="/about"
>
  <header class="page-header">
    <div class="container container--narrow">
      <h1>About</h1>
    </div>
  </header>

  <section class="page-section">
    <div class="container container--narrow">
      <div class="about-intro">
        <figure class="about-portrait">
          <img
            src="/images/jim-mccarthy-portrait.jpg"
            alt="James R. McCarthy"
            width="655"
            height="1024"
            loading="eager"
          />
        </figure>
        <div class="about-intro__text">
          <p>
            I am {site.legalName}. I go by Jim. {resume.summary}
          </p>
          <p>
            I believe AI-native operating models produce startup build velocity at incumbent scale.
            Builder, product, and operator roles are converging. When build compresses, the bottleneck
            moves to design and review. The organizations that win will not buy the most tools. They
            will be the ones where everyone builds, with human judgment elevated on the decisions that
            carry accountability.
          </p>
          <p>
            I treat AI as operating leverage, not theater. Speed is an advantage only when timing and
            enrollment are right. I replace narrative reporting with facts, owners, dates, closure
            definitions, and verification loops.
          </p>
        </div>
      </div>
    </div>

    <div class="container container--narrow prose">
      <section class="about-ventures" aria-labelledby="about-ventures-heading">
        <h2 id="about-ventures-heading" class="about-ventures__heading">Building beyond operations</h2>
        {
          aboutVentures.map((venture) => (
            <div class="about-venture">
              <h3>
                {venture.name}
                {venture.role && <span class="about-venture__meta"> · {venture.role}</span>}
              </h3>
              {venture.paragraphs.map((paragraph) => (
                <p>{paragraph}</p>
              ))}
            </div>
          ))
        }
      </section>
    </div>

    <div class="container container--narrow prose">
      <section class="about-experience" aria-labelledby="about-experience-heading">
        <h2 id="about-experience-heading" class="about-experience__heading">Experience</h2>
        {
          resume.roles.map((role) => (
            <div class="role-block">
              <h3>
                {role.company}
                {(role.title || role.period) && (
                  <span class="role-block__meta">
                    {role.title && ` · ${role.title}`}
                    {role.period && ` · ${role.period}`}
                  </span>
                )}
              </h3>
              <ul>
                {role.bullets.map((bullet) => (
                  <li>{bullet}</li>
                ))}
              </ul>
            </div>
          ))
        }

        <p class="about-education">{resume.education}</p>
      </section>
    </div>

    <div class="container container--narrow">
      <p class="about-credential">{site.role}</p>
    </div>
  </section>
</BaseLayout>
