---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  path?: string;
}

const {
  title = site.pageTitle,
  description = site.description,
  path = '/',
} = Astro.props;

const isHome = title === site.pageTitle;
const pageTitle = isHome
  ? site.pageTitle
  : `${title} · ${site.legalName} (${site.name})`;
const canonical = new URL(path, site.url).href;

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.legalName,
  alternateName: site.name,
  givenName: 'James',
  familyName: 'McCarthy',
  additionalName: 'R.',
  jobTitle: 'Chief Operating Officer',
  worksFor: {
    '@type': 'Organization',
    name: 'Vixxo',
  },
  url: site.url,
  email: site.email,
  sameAs: [site.linkedin, site.url],
  description: site.thesis,
  knowsAbout: [
    'AI-native operating models',
    'Continuous improvement',
    'Enterprise operations',
    'Software development lifecycle',
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content={site.legalName} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title={`${site.legalName} — Writing`} href="/rss.xml" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.legalName} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <Analytics />
  </head>
  <body>
    <div class="site-shell">
      <Header currentPath={path} />
      <main class="site-main">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
